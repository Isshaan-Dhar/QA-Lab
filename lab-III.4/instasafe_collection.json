  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "const currentToken = pm.environment.get('auth_token');",
          "const tokenExpiry = pm.environment.get('auth_token_expiry');",
          "const now = new Date().getTime();",
          "if (!currentToken || !tokenExpiry || now >= tokenExpiry) {",
          "    const loginRequest = {",
          "        url: pm.environment.get('base_url') + '/auth/login',",
          "        method: 'POST',",
          "        header: { 'Content-Type': 'application/json' }",
          "    };",
          "    pm.sendRequest(loginRequest, function (err, res) {",
          "        if (!err && res.code === 200) {",
          "            const data = res.json();",
          "            pm.environment.set('auth_token', data.access_token);",
          "            pm.environment.set('auth_token_expiry', new Date().getTime() + (data.expires_in * 1000));",
          "        }",
          "    });",
          "}"
        ]
      }
    },
