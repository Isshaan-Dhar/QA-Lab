    {
      "name": "POST /devices",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "const expectedStatus = pm.variables.get(\"expected_status\");",
              "",
              "if (expectedStatus === \"201\") {",
              "    pm.test(\"Device enrolment returns 201 Created\", () => {",
              "        pm.expect(pm.response.code).to.equal(201);",
              "    });",
              "    pm.test(\"Device schema validation\", () => {",
              "        pm.expect(response).to.have.property(\"id\");",
              "        pm.expect(response).to.have.property(\"hostname\");",
              "        pm.expect(response).to.have.property(\"os\");",
              "    });",
              "    if (response && response.id) {",
              "        pm.collectionVariables.set(\"active_device_id\", response.id);",
              "    }",
              "} else if (expectedStatus === \"400\") {",
              "    pm.test(\"Validation failure returns 400 Bad Request\", () => {",
              "        pm.expect(pm.response.code).to.equal(400);",
              "    });",
              "    pm.test(\"Error payload contains message\", () => {",
              "        pm.expect(response).to.have.property(\"error\");",
              "    });",
              "}",
              "",
              "pm.test(\"Response time is less than 2000ms\", () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
